Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS + 非www を正規URLへ統一
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.playpoint-sim\.com$ [NC]
  RewriteRule ^ https://playpoint-sim.com%{REQUEST_URI} [R=301,L]

  # 旧URLをトップへ統一
  RewriteCond %{THE_REQUEST} \s/+calculator\.html[\s?] [NC]
  RewriteRule ^calculator\.html$ / [R=301,L,NE]

  # /index.html をルートへ統一
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L,NE]
</IfModule>

<IfModule mod_deflate.c>
  # 転送量を減らして表示速度を改善
  AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # HTMLは短め、静的アセットは長めにキャッシュ
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
  Header append Vary Accept-Encoding
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:; frame-src https:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'"
</IfModule>
