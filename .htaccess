Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS + 非www を正規URLへ統一
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.playpoint-sim\.com$ [NC]
  RewriteRule ^ https://playpoint-sim.com%{REQUEST_URI} [R=301,L]

  # 旧URLをトップへ統一
  RewriteCond %{THE_REQUEST} \s/+calculator\.html[\s?] [NC]
  RewriteRule ^calculator\.html$ / [R=301,L,NE]

  # /index.html をルートへ統一
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L,NE]
</IfModule>

